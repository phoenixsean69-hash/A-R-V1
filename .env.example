# Browser key from Google Cloud -> APIs & Services -> Credentials.
# Enable Maps JavaScript API, Places API (New), and Geocoding API.
# Restrict it as a Website key and allow the exact origins you use, for example:
#   http://localhost:5173
#   http://127.0.0.1:5173
#   https://your-production-domain.example
VITE_GOOGLE_MAPS_BROWSER_KEY=

# JavaScript Map ID from Google Maps Platform -> Map Management.
# Leave blank during development to use Google's DEMO_MAP_ID.
VITE_GOOGLE_MAPS_MAP_ID=

# Optional secured backend endpoint for Roads API road geometry/context.
# Do not expose a Roads API server key through a VITE_ variable.
VITE_GOOGLE_ROADS_PROXY_URL=
